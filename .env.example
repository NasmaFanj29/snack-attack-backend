# ==========================================
# DATABASE CONFIGURATION
# ==========================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password_here
DB_DATABASE=snack_attack
# Alternative: some deployments use DB_NAME instead of DB_DATABASE
# DB_NAME=snack_attack
DB_CONNECTION_LIMIT=10
DB_REQUIRE_SSL=false
DB_REJECT_UNAUTHORIZED=true

# ==========================================
# JWT AUTHENTICATION
# ==========================================
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_minimum_32_chars
JWT_EXPIRES_IN=8h

# ==========================================
# STRIPE PAYMENT PROCESSING
# ==========================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here

# ==========================================
# GOOGLE GEMINI AI (Chat/Ordering)
# ==========================================
GEMINI_API_KEY=your_google_gemini_api_key_here

# ==========================================
# CORS & SECURITY
# ==========================================
# Comma-separated allowed origins (no spaces)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://yourdomain.com

# ==========================================
# SERVER & ENVIRONMENT
# ==========================================
NODE_ENV=development
PORT=5000

# ==========================================
# STAFF USERS (JSON format, optional)
# If not set, defaults to hardcoded users in middleware/auth.js
# Format: [{"username":"user1","password":"pass1","role":"admin","name":"Name"}]
# ==========================================
# STAFF_USERS_JSON=[{"username":"admin","password":"snack2024","role":"admin","name":"Admin"}]
